# Project-wide ignores

# IDE
.vscode/
.idea/
*.iml
*.iws
*.ipr

# OS
.DS_Store
Thumbs.db

# Build outputs (backend)
backend/target/
mobile/.gradle/
mobile/build/
mobile/app/build/
mobile/local.properties
mobile/app/local.properties

# Node modules (web)
web/node_modules/

# Environment files (secrets)
.env
.env.local
.env*.local
backend/.env
web/.env.local

# Backend configuration with sensitive data
backend/src/main/resources/application.properties
backend/src/main/resources/application-*.properties

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
