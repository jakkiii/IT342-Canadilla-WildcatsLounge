<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/wildcats_cream"
	android:orientation="vertical"
	android:padding="@dimen/spacing_md">

	<include layout="@layout/include_page_header" />

	<LinearLayout
		android:id="@+id/cartEmptyState"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="@dimen/spacing_md"
		android:background="@drawable/bg_card"
		android:gravity="center"
		android:orientation="vertical"
		android:padding="28dp"
		android:visibility="gone">

		<FrameLayout
			android:layout_width="64dp"
			android:layout_height="64dp"
			android:background="@drawable/bg_icon_chip">

			<ImageView
				android:layout_width="32dp"
				android:layout_height="32dp"
				android:layout_gravity="center"
				android:contentDescription="@null"
				android:src="@drawable/ic_cart" />
		</FrameLayout>

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="Your cart is empty"
			android:textColor="@color/text_primary"
			android:textStyle="bold" />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="4dp"
			android:gravity="center"
			android:text="Browse the menu and add your favorite drinks or treats."
			android:textColor="@color/text_secondary"
			android:textSize="13sp" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/btnBrowseMenu"
			style="@style/WildcatsPrimaryButton"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:text="Browse menu"
			app:backgroundTint="@null"
			app:icon="@drawable/ic_local_cafe"
			app:iconTint="@color/white" />
	</LinearLayout>

	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/recyclerCart"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_marginTop="@dimen/spacing_sm"
		android:layout_weight="1"
		android:clipToPadding="false"
		android:paddingBottom="8dp" />

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="@dimen/spacing_sm"
		android:background="@drawable/bg_card"
		android:orientation="vertical"
		android:padding="@dimen/spacing_md">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_vertical"
			android:orientation="horizontal">

			<FrameLayout
				android:layout_width="40dp"
				android:layout_height="40dp"
				android:background="@drawable/bg_icon_chip">

				<ImageView
					android:layout_width="22dp"
					android:layout_height="22dp"
					android:layout_gravity="center"
					android:contentDescription="@null"
					android:src="@drawable/ic_receipt" />
			</FrameLayout>

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="10dp"
				android:layout_weight="1"
				android:text="Order total"
				android:textColor="@color/text_secondary" />

			<TextView
				android:id="@+id/tvSubtotal"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="₱0.00"
				android:textColor="@color/wildcats_blue"
				android:textSize="18sp"
				android:textStyle="bold" />
		</LinearLayout>

		<com.google.android.material.button.MaterialButton
			android:id="@+id/btnPlaceOrder"
			style="@style/WildcatsPrimaryButton"
			android:layout_width="match_parent"
			android:layout_height="52dp"
			android:layout_marginTop="12dp"
			android:text="@string/label_place_order"
			app:backgroundTint="@null"
			app:icon="@drawable/ic_cart"
			app:iconTint="@color/white" />
	</LinearLayout>
</LinearLayout>
