<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/wildcats_cream"
	android:orientation="vertical"
	android:padding="@dimen/spacing_md">

	<include layout="@layout/include_page_header" />

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="@dimen/spacing_sm"
		android:background="@drawable/bg_card"
		android:gravity="center_vertical"
		android:orientation="horizontal"
		android:padding="14dp">

		<FrameLayout
			android:layout_width="40dp"
			android:layout_height="40dp"
			android:background="@drawable/bg_icon_chip">

			<ImageView
				android:layout_width="22dp"
				android:layout_height="22dp"
				android:layout_gravity="center"
				android:contentDescription="@null"
				android:src="@drawable/ic_events" />
		</FrameLayout>

		<TextView
			android:id="@+id/tvEventsSummary"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_marginStart="12dp"
			android:layout_weight="1"
			android:textColor="@color/text_secondary"
			android:textSize="13sp" />
	</LinearLayout>

	<TextView
		android:id="@+id/tvEventsEmpty"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="24dp"
		android:gravity="center"
		android:padding="16dp"
		android:text="No events scheduled. Check back later."
		android:textColor="@color/text_secondary"
		android:visibility="gone" />

	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/recyclerEvents"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_marginTop="@dimen/spacing_sm"
		android:layout_weight="1"
		android:clipToPadding="false"
		android:paddingBottom="8dp" />
</LinearLayout>
