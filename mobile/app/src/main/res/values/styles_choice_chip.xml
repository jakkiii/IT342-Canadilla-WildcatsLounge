		<item name="android:textSize">13sp</item>
		<item name="android:textColor">@color/chip_choice_text</item>
		<item name="chipBackgroundColor">@color/chip_choice_bg</item>
		<item name="chipStrokeColor">@color/chip_choice_stroke</item>
		<item name="chipStrokeWidth">2dp</item>
		<item name="chipCornerRadius">@dimen/radius_chip</item>
		<item name="chipMinHeight">40dp</item>
		<item name="checkedIconVisible">false</item>
