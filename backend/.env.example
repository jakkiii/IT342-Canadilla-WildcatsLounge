# Copy to .env and fill in (never commit .env)

# ── Recommended: Session pooler (works on IPv4 / most home networks) ──
# Supabase → Settings → Database → Pooler settings → Session mode
# From: postgres://postgres.YOUR_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres
DB_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD="your-database-password"

# ── Direct connection (IPv6 only — often fails on Windows without IPv6) ──
# DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# DB_USERNAME=postgres

JWT_SECRET="your-jwt-secret-at-least-32-characters-long"
SERVER_PORT=8080

# Gmail / SMTP for verification emails
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME="your-sender@gmail.com"
MAIL_PASSWORD="your-google-app-password"
MAIL_FROM="your-sender@gmail.com"
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
