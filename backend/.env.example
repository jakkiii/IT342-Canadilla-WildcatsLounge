# Local PostgreSQL defaults
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wildcats_lounge
DB_USERNAME=postgres
DB_USERNAME_SUFFIX=
DB_PASSWORD=postgres

# Optional: use a single JDBC URL instead of host/port/name values
# Direct Supabase connection example:
# DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Supabase pooler example (fixes "Tenant or user not found"):
# DB_URL=jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# DB_USERNAME=postgres
# DB_USERNAME_SUFFIX=.YOUR_PROJECT_REF
# DB_PASSWORD=YOUR_DATABASE_PASSWORD

JWT_SECRET=your-secret-key-at-least-32-characters-long
